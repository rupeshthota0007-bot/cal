# MongoDB Atlas connection string (required for permanent storage on Vercel)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Secret key for signing auth tokens — change this to a random string!
AUTH_SECRET=change-this-secret-before-production

# (Local dev only) Path to the fallback JSON user file
AUTH_DATA_FILE=./backend/.data/users.json
